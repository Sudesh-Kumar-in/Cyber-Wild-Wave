# ══════════════════════════════════════════════════════════════
# 🔥 CYBER WILD WAVE — Railway / .env Variable Reference
# ══════════════════════════════════════════════════════════════
# Add these as Railway environment variables (not a .env file).
# Never commit actual secrets to version control.

# ── Required ──────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# ── API Authentication ─────────────────────────────────────────
# Sent automatically as: Authorization: Bearer <key> and X-Api-Key: <key>
# Leave blank if your API uses key-in-URL only (e.g. ?key=abc in the URL below).
API_KEY=

# ── API Endpoint URL Templates ────────────────────────────────
# ⚠️  IMPORTANT: The bot needs SEVEN separate URL variables, one per lookup type.
#     Do NOT use a single API_URL variable — it will be ignored.
#
# Put the search term placeholder in the URL as {query}.
# The bot also accepts: {num} {mobile} {number} {q} and lookup-specific names.
#
# Example (number lookup via paid-flix API):
#   API_NUMBER_LOOKUP=https://paid-flix-num-info-api.alphamovies.workers.dev/?num={query}&key=YOUR_KEY
#
# Leave a variable blank to use the built-in free fallback (pincode/IFSC only)
# or to show demo data (telegram/aadhaar/family/vehicle).

API_NUMBER_LOOKUP=https://your-api.example.com/number?q={query}&key=YOUR_KEY
API_TELEGRAM_LOOKUP=https://your-api.example.com/telegram?q={query}&key=YOUR_KEY
API_AADHAAR_LOOKUP=https://your-api.example.com/aadhaar?q={query}&key=YOUR_KEY
API_FAMILY_LOOKUP=https://your-api.example.com/family?q={query}&key=YOUR_KEY
API_VEHICLE_LOOKUP=https://your-api.example.com/vehicle?q={query}&key=YOUR_KEY

# These two have free public fallbacks — leave blank to use them automatically:
API_PINCODE_LOOKUP=
API_IFSC_LOOKUP=

# ── Optional ──────────────────────────────────────────────────
# Force-join channel handle (e.g. @mychannel). Leave blank to disable.
REQUIRED_CHANNEL=
CHANNEL_INVITE_LINK=https://t.me/yourchannel

# SQLite database file path (default: bot.db)
DATABASE_PATH=bot.db

# Free daily searches for non-premium users (default: 5)
FREE_DAILY_SEARCHES=5

# Seconds between requests per user (default: 3)
RATE_LIMIT_SECONDS=3

# API response cache TTL in seconds (default: 300)
CACHE_TTL=300
