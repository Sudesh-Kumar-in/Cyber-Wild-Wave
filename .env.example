# ══════════════════════════════════════════
# 🔥 CYBER WILD WAVE — Environment Config
# ══════════════════════════════════════════
# Copy this file to .env and fill in values.
# Never commit your .env to version control.

# ── Required ───────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
API_URL=YOUR_API_URL_HERE
API_KEY=your_api_key_here
ADMIN_IDS=123456789,987654321
SESSION_SECRET=change_this_to_a_random_secret

# ── Optional ───────────────────────────────
# Force-join channel invite link (leave blank to disable)
CHANNEL_INVITE_LINK=

# SQLite database file path (default: bot.db)
DATABASE_PATH=bot.db

# Free daily searches for non-premium users (default: 5)
FREE_DAILY_SEARCHES=5

# Seconds between requests per user (default: 3)
RATE_LIMIT_SECONDS=3

# API response cache TTL in seconds (default: 300)
CACHE_TTL=300
